# ------------------------------------------------------------------
# Environment configuration template.
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
# The real `.env` is git-ignored and must never be committed.
# ------------------------------------------------------------------

# Port the Express server listens on.
PORT=5000

# ------------------------------------------------------------------
# Neon Postgres — Prisma connection strings
# ------------------------------------------------------------------
# DATABASE_URL: used by the Prisma Client at runtime. Use Neon's POOLED
# endpoint (host contains "-pooler"). `sslmode=require` is mandatory for Neon.
# Format:
#   postgresql://<user>:<password>@<host>-pooler.<region>.aws.neon.tech/<db>?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# DIRECT_URL: used ONLY by Prisma Migrate (schema changes). Point this at the
# Neon DIRECT (non-pooler) endpoint to avoid advisory-lock issues over PgBouncer.
# Optional for basic runtime; recommended before running `prisma migrate`.
#   postgresql://<user>:<password>@<host>.<region>.aws.neon.tech/<db>?sslmode=require
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DBNAME?sslmode=require"
