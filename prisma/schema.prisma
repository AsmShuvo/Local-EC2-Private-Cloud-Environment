// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model CloudProject {
  id           Int      @id @default(autoincrement())
  name         String
  description  String?
  status       String   @default("RUNNING")
  instanceName String?  @unique
  ipAddress    String?
  keyName      String? // display label of the key pair used (nullable = launched without one)
  cpu          Int      @default(1)
  memory       String   @default("1G")
  instanceType String   @default("t2.micro")
  disk         String   @default("5G")
  os           String   @default("ubuntu") // which image the VM was built from
  createdAt    DateTime @default(now())

  // The reusable key pair this instance was launched with (AWS: an instance
  // references a key pair; the private half is never stored server-side).
  keyPairId Int?
  keyPair   KeyPair? @relation(fields: [keyPairId], references: [id], onDelete: SetNull)

  // Many-to-many: an instance can have many security groups, and a security
  // group can be attached to many instances (implicit join table).
  securityGroups SecurityGroup[] @relation("InstanceSecurityGroups")
}

// A reusable key pair, exactly like an AWS EC2 key pair.
//
// SECURITY MODEL: we store ONLY the public key (safe to persist). The private
// key is handed to the user exactly once at creation and never kept. Selecting
// an "existing" key pair re-injects its stored PUBLIC key into the new VM, so
// the user's already-downloaded .pem keeps working.
model KeyPair {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  publicKey   String // OpenSSH authorized_keys format ("ssh-rsa AAAA...")
  fingerprint String? // SHA256:... like `ssh-keygen -l`
  createdAt   DateTime @default(now())

  instances CloudProject[]
}

model SecurityGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  rules     SecurityRule[]
  instances CloudProject[] @relation("InstanceSecurityGroups")
}

// One table for both directions — `direction` discriminates INBOUND/OUTBOUND.
// Simpler and more scalable than two near-identical tables; the API still
// presents them grouped as inboundRules / outboundRules.
model SecurityRule {
  id        Int      @id @default(autoincrement())
  groupId   Int
  direction String   @default("INBOUND") // INBOUND | OUTBOUND
  protocol  String   @default("TCP") // TCP | UDP | ICMP | ALL
  fromPort  Int? // null = all ports
  toPort    Int? // null => single port (= fromPort)
  sourceIp  String   @default("0.0.0.0/0") // CIDR; bare IP treated as /32
  createdAt DateTime @default(now())

  group SecurityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, direction])
}
